# =============================================================================
# Open Music Player - Environment Variables
# =============================================================================
# Copy this file to .env and update values as needed:
#   cp .env.example .env
#
# SECURITY: Never commit .env files with real credentials to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Port the backend server listens on (inside container)
SERVER_ADDR=:8080
# Port exposed to host machine
SERVER_PORT=8080

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=omp
# IMPORTANT: Change this in production!
POSTGRES_PASSWORD=omp_dev_password
POSTGRES_DB=openmusicplayer
# Host port mapping (container always uses 5432 internally)
POSTGRES_PORT=5434

# Connection URL for application use (used when running outside Docker)
DATABASE_URL=postgresql://omp:omp_dev_password@localhost:5434/openmusicplayer

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
# Enable Redis-backed queue/pubsub/download APIs. Set to false for the low-memory
# backend control-plane profile when downloads and playback queue are not under test.
REDIS_ENABLED=true
# Host port mapping (container always uses 6379 internally)
REDIS_PORT=6380

# Connection URL for application use (used when running outside Docker)
REDIS_URL=redis://localhost:6380

# -----------------------------------------------------------------------------
# MinIO Configuration (S3-compatible object storage)
# -----------------------------------------------------------------------------
# IMPORTANT: Change these in production!
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=audio-files

# S3-compatible credentials for application use
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Endpoint (used when running outside Docker)
MINIO_ENDPOINT=http://localhost:9000
# Browser/devbox-reachable endpoint used only when issuing presigned playback URLs.
# Leave unset outside Docker unless the public URL differs from MINIO_ENDPOINT.
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# -----------------------------------------------------------------------------
# Authentication Configuration
# -----------------------------------------------------------------------------
# IMPORTANT: Generate a secure random secret for production!
# Example: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# Optional comma-separated browser origins allowed to call the backend from Flutter Web.
# Unset defaults to local Flutter Web dev origins; set empty to disable CORS headers.
# OMP_CORS_ALLOWED_ORIGINS=http://localhost:18145,http://127.0.0.1:18145

# -----------------------------------------------------------------------------
# Worker Configuration
# -----------------------------------------------------------------------------
# Number of concurrent download workers. Keep this low locally; use 0 to leave
# downloads queued but not processed while testing backend control-plane or web UI.
WORKER_COUNT=1

# -----------------------------------------------------------------------------
# Production Nginx Configuration (optional)
# -----------------------------------------------------------------------------
# These are only used when running with --profile production
HTTP_PORT=80
HTTPS_PORT=443

# -----------------------------------------------------------------------------
# AI Assist Configuration (optional, grounded search assistant)
# -----------------------------------------------------------------------------
# OpenAI-compatible chat-completions endpoint used by POST /api/v1/discovery/assist.
# The assistant only turns natural language into a search/source intent; it never
# produces playable/download URLs. Leave unset to disable: normal discovery search
# and direct URL resolution work without it. Enabled automatically when base URL,
# key, and model are all set; force off with AI_ASSIST_ENABLED=false.
# SECURITY: AI_ASSIST_API_KEY is a secret and is never logged.
# AI_ASSIST_BASE_URL=https://api.openai.com/v1
# AI_ASSIST_API_KEY=change-me
# AI_ASSIST_MODEL=gpt-4o-mini
# AI_ASSIST_ENABLED=true
# AI_ASSIST_TIMEOUT_MS=8000

# -----------------------------------------------------------------------------
# Metadata LLM Disambiguator (optional, local Ollama)
# -----------------------------------------------------------------------------
# Local Ollama structured-output helper used only after MusicBrainz candidates
# exist. It selects among existing candidates; it never browses URLs or writes
# metadata directly. Disabled by default and safe to leave unset.
# METADATA_LLM_ENABLED=false
# METADATA_LLM_BASE_URL=http://localhost:11434
# METADATA_LLM_MODEL=llama3.1
# METADATA_LLM_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# Source-quality LLM judge (optional, local Ollama)
# -----------------------------------------------------------------------------
# Reranks only the discovered source candidates. Disabled by default; a missing
# or failing judge keeps deterministic source-quality ranking. The base URL and
# model fall back to OLLAMA_BASE_URL and OLLAMA_MODEL before local defaults.
# SECURITY: OLLAMA_API_KEY is optional and is never logged.
# SOURCE_QUALITY_LLM_ENABLED=false
# Native backend default: http://localhost:11434. Docker Compose defaults to
# http://host.docker.internal:11434 so the backend container can reach Ollama on
# its host (with a Linux host-gateway mapping). For a tailnet or other remote
# provider, set SOURCE_QUALITY_LLM_BASE_URL explicitly; do not commit endpoints
# or credentials.
# SOURCE_QUALITY_LLM_BASE_URL=http://localhost:11434
# SOURCE_QUALITY_LLM_MODEL=source-quality-judge
# SOURCE_QUALITY_LLM_TIMEOUT_MS=1500
# OLLAMA_API_KEY=change-me

# -----------------------------------------------------------------------------
# Private agent research tools (optional)
# -----------------------------------------------------------------------------
# Enables only the internal async-agent gateway at /internal/agent-tools/v1.
# Keep this service token and the Firecrawl API key out of logs, prompts, and
# source control. Without OMP_AGENT_SERVICE_TOKEN the gateway has no route;
# normal deterministic discovery is unchanged. FIRECRAWL_API_KEY is optional:
# source/catalog tools work without it, while extract-web returns a typed
# FIRECRAWL_DISABLED response.
# OMP_AGENT_SERVICE_TOKEN=change-me
# FIRECRAWL_API_KEY=change-me
# Future Python async worker client (not wired to synchronous discovery/evals).
# AGENT_TOOL_GATEWAY_URL=https://gateway-host.example
# AGENT_TOOL_GATEWAY_SERVICE_TOKEN=change-me
# AGENT_TOOL_GATEWAY_TIMEOUT_S=5
# HTTPS is required by default. For local development only, the Python client
# accepts this exact lowercase opt-in; keep it unset in shared environments.
# AGENT_TOOL_GATEWAY_ALLOW_INSECURE_HTTP=false

# -----------------------------------------------------------------------------
# Durable research jobs (optional, deterministic baseline always retained)
# -----------------------------------------------------------------------------
# RESEARCH_ENABLED controls only model enhancement. The authenticated research
# routes remain available and revision 1 is built through existing deterministic
# discovery. With enhancement disabled, the research worker records a typed
# model_disabled degradation without deleting the baseline.
RESEARCH_ENABLED=false
# Native API processes keep the existing durable worker behavior by default.
# Compose API services override this to false and use the explicit
# research-worker profile against the same Postgres DB.
# RESEARCH_WORKER_ENABLED=true
# RESEARCH_WORKER_ID=research-hostname
# RESEARCH_MAX_ATTEMPTS=3

# Child command and arguments are operator-owned. Arguments are a JSON array,
# never a shell string. The child receives only the exact AGENT_SEARCH_ model
# variables below plus normal runtime PATH/HOME/locale values; server auth,
# database, Redis, storage, gateway, and Firecrawl secrets are not forwarded.
# RESEARCH_COMMAND=candidate-assembly-worker
# RESEARCH_COMMAND_ARGS=["--once"]

# Exact model variables consumed by candidate-assembly-worker when enhancement
# is enabled. Keep AGENT_SEARCH_API_KEY in a secret store; do not commit it.
# AGENT_SEARCH_BASE_URL=https://models.example/v1
# AGENT_SEARCH_API_KEY=change-me
# AGENT_SEARCH_MODEL=your-model
# AGENT_SEARCH_TIMEOUT_S=90
# AGENT_SEARCH_RUN_TIMEOUT_S=3600

# Stage selection and bounded worker request budget. The direct judge stays
# independent. Deep-agent rollout is disabled until every required dark-launch
# control is deliberately configured by an operator.
# RESEARCH_DIRECT_JUDGE_ENABLED=true
RESEARCH_DEEP_AGENT_ENABLED=false
RESEARCH_DEEP_AGENT_DARK_LAUNCH_ENABLED=false
RESEARCH_DEEP_AGENT_SURFACE_REVISIONS=false
RESEARCH_DEEP_AGENT_COHORT_BPS=0
RESEARCH_DEEP_AGENT_WEB_ENABLED=false
# Before a server integration starts or surfaces deep-agent work, call
# Config.ValidateResearchRollout(). Surface revisions require both deep-agent
# and dark-launch flags. RESEARCH_DEEP_AGENT_WEB_ENABLED is rejected in every
# production worker configuration. Firecrawl is gateway-eval-only and is never
# forwarded into worker prompts or artifacts.
# RESEARCH_MAX_TOOL_CALLS=8
# RESEARCH_MAX_MODEL_CALLS=10
# RESEARCH_RECURSION_LIMIT=12
# RESEARCH_MAX_CANDIDATES_IN=25
# RESEARCH_MAX_RECOMMENDATIONS=10
# RESEARCH_WALL_CLOCK_MS=180000
# RESEARCH_MAX_REQUEST_BYTES=49152
# RESEARCH_MAX_RESPONSE_BYTES=65536
# RESEARCH_MAX_TOKENS=4096

# Postgres-backed daily reservations, per-user runtime slots, and bounded
# lease/poll/process lifecycle. No Redis/download/playback worker is involved.
# RESEARCH_DAILY_UNITS_PER_ATTEMPT=1
# RESEARCH_DAILY_LIMIT=10
# RESEARCH_MAX_CONCURRENT_PER_USER=1
# RESEARCH_POLL_INTERVAL_MS=1000
# RESEARCH_LEASE_DURATION_MS=30000
# RESEARCH_RENEW_INTERVAL_MS=10000
# RESEARCH_RUN_TIMEOUT_MS=120000
# RESEARCH_CANCEL_GRACE_MS=2000
# RESEARCH_SHUTDOWN_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Save Playlist as Mix (optional, flag-gated backend seam)
# -----------------------------------------------------------------------------
# When enabled, exposes POST /api/v1/playlists/{id}/mix, which creates a saved
# mix_plan from a playlist's ordered tracks (one clip per track, laid end-to-end
# with no crossfade or analysis). Disabled by default; the endpoint returns 404
# while off. This is a backend seam only — no DJ/waveform/mix-editing UI.
# ENABLE_PLAYLIST_MIX=false

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=info
