# =============================================================================
# Open Music Player - Environment Variables
# =============================================================================
# Copy this file to .env and update values as needed:
#   cp .env.example .env
#
# SECURITY: Never commit .env files with real credentials to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Port the backend server listens on (inside container)
SERVER_ADDR=:8080
# Port exposed to host machine
SERVER_PORT=8080

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=omp
# IMPORTANT: Change this in production!
POSTGRES_PASSWORD=omp_dev_password
POSTGRES_DB=openmusicplayer
# Host port mapping (container always uses 5432 internally)
POSTGRES_PORT=5434

# Connection URL for application use (used when running outside Docker)
DATABASE_URL=postgresql://omp:omp_dev_password@localhost:5434/openmusicplayer

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
# Enable Redis-backed queue/pubsub/download APIs. Set to false for the low-memory
# backend control-plane profile when downloads and playback queue are not under test.
REDIS_ENABLED=true
# Host port mapping (container always uses 6379 internally)
REDIS_PORT=6380

# Connection URL for application use (used when running outside Docker)
REDIS_URL=redis://localhost:6380

# -----------------------------------------------------------------------------
# MinIO Configuration (S3-compatible object storage)
# -----------------------------------------------------------------------------
# IMPORTANT: Change these in production!
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=audio-files

# S3-compatible credentials for application use
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Endpoint (used when running outside Docker)
MINIO_ENDPOINT=http://localhost:9000
# Browser/devbox-reachable endpoint used only when issuing presigned playback URLs.
# Leave unset outside Docker unless the public URL differs from MINIO_ENDPOINT.
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# -----------------------------------------------------------------------------
# Authentication Configuration
# -----------------------------------------------------------------------------
# IMPORTANT: Generate a secure random secret for production!
# Example: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# Optional comma-separated browser origins allowed to call the backend from Flutter Web.
# Unset defaults to local Flutter Web dev origins; set empty to disable CORS headers.
# OMP_CORS_ALLOWED_ORIGINS=http://localhost:18145,http://127.0.0.1:18145

# -----------------------------------------------------------------------------
# Worker Configuration
# -----------------------------------------------------------------------------
# Number of concurrent download workers. Keep this low locally; use 0 to leave
# downloads queued but not processed while testing backend control-plane or web UI.
WORKER_COUNT=1

# -----------------------------------------------------------------------------
# Production Nginx Configuration (optional)
# -----------------------------------------------------------------------------
# These are only used when running with --profile production
HTTP_PORT=80
HTTPS_PORT=443

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=info
