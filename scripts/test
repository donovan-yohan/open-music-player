#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TARGET="${1:-all}"

run_delivery() {
  "$ROOT/scripts/agentic-cycle" --self-test
}

run_backend() {
  (
    cd "$ROOT/backend"
    go_test_args=()
    if [ -n "${OMP_POSTGRES_TEST_DSN:-${QA_DATABASE_URL:-${DATABASE_URL:-}}}" ]; then
      # Integration packages truncate shared fixtures; one DSN requires
      # package-serial execution to prevent cross-package deadlocks.
      go_test_args+=(-p 1)
    fi
    if [ -n "${BACKEND_GO_TEST_ARGS:-}" ]; then
      # shellcheck disable=SC2206
      extra_args=(${BACKEND_GO_TEST_ARGS})
      go_test_args+=("${extra_args[@]}")
    fi
    go test "${go_test_args[@]}" ./...
  )
}

run_analyzer() {
  docker build \
    --target analyzer-test \
    --tag open-music-player-analyzer-test:local \
    "$ROOT/backend"
}

run_client() {
  (
    cd "$ROOT/client"
    flutter pub get
    if [ -n "${FLUTTER_TEST_ARGS:-}" ]; then
      # shellcheck disable=SC2206
      extra_args=(${FLUTTER_TEST_ARGS})
      flutter test "${extra_args[@]}"
    else
      flutter test
    fi
  )
}

run_extension() {
  (
    cd "$ROOT/extension"
    if [ ! -d node_modules ]; then
      npm ci
    fi
    npm run type-check
    npm run test:auth-refresh
  )
}

case "$TARGET" in
  delivery|harness)
    run_delivery
    ;;
  backend)
    run_backend
    ;;
  analyzer)
    run_analyzer
    ;;
  client)
    run_client
    ;;
  extension)
    run_extension
    ;;
  all)
    run_delivery
    run_backend
    run_analyzer
    run_client
    run_extension
    ;;
  *)
    echo "usage: scripts/test [delivery|harness|backend|analyzer|client|extension|all]" >&2
    exit 2
    ;;
esac
