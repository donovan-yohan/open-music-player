#!/usr/bin/env python3
"""Deterministic delivery scaffolding checks for Open Music Player."""
from __future__ import annotations

import ast
import json
import os
import re
import subprocess
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
FAILURES: list[str] = []

SECRET_PATTERNS = [
    re.compile(r"-----BEGIN (?:RSA |OPENSSH |EC |DSA )?PRIVATE KEY-----"),
    re.compile(r"ghp_[A-Za-z0-9_]{20,}"),
    re.compile(r"github_pat_[A-Za-z0-9_]{20,}"),
    re.compile(r"sk-[A-Za-z0-9]{20,}"),
    re.compile(r"xox[baprs]-[A-Za-z0-9-]{20,}"),
    re.compile(r"https?://[^\s:/]+:[^\s@/]+@"),
    re.compile(
        r"(?i)\b(api[_-]?key|access[_-]?token|auth[_-]?token|password|client[_-]?secret)\b"
        r"\s*[:=]\s*['\"][A-Za-z0-9_./+=:-]{20,}['\"]"
    ),
]
PLACEHOLDER_HINTS = (
    "example",
    "placeholder",
    "redacted",
    "your_",
    "xxxx",
    "<token",
    "env var",
    "os.environ",
    "os.getenv",
    "changeme",
    "dummy",
    "expired-",
    "fake",
    "mock",
    "test:test",
    "valid-",
)
TEXT_SUFFIXES = {
    "",
    ".bash",
    ".dart",
    ".env",
    ".go",
    ".html",
    ".js",
    ".json",
    ".lock",
    ".md",
    ".py",
    ".sh",
    ".sql",
    ".ts",
    ".txt",
    ".yaml",
    ".yml",
}
SKIP_PARTS = {
    ".dart_tool",
    ".git",
    ".gradle",
    ".idea",
    "build",
    "coverage",
    "dist",
    "node_modules",
}


def fail(message: str) -> None:
    FAILURES.append(message)


def repo_files() -> list[Path]:
    out = subprocess.check_output(
        ["git", "ls-files", "--cached", "--others", "--exclude-standard", "-z"],
        cwd=ROOT,
    )
    files = []
    for raw in out.split(b"\0"):
        if not raw:
            continue
        rel = Path(raw.decode())
        if any(part in SKIP_PARTS for part in rel.parts):
            continue
        files.append(ROOT / rel)
    return files


def rel(path: Path) -> str:
    return path.relative_to(ROOT).as_posix()


def read_text(path: Path) -> str | None:
    if path.suffix.lower() not in TEXT_SUFFIXES:
        return None
    try:
        text = path.read_text(errors="replace")
    except Exception:
        return None
    if "\0" in text[:4096]:
        return None
    return text


def check_required_files() -> None:
    for name in [
        "AGENTS.md",
        "docs/context-map.md",
        "docs/agentic-delivery.md",
        "docs/adr/0001-playback-timeline-source-of-truth.md",
        "scripts/dev",
        "scripts/test",
        "scripts/lint",
        "scripts/build",
        "scripts/smoke",
        "scripts/dogfood-android",
        "scripts/agentic-cycle",
        "scripts/agentic-harness",
        "scripts/release-audit",
        ".github/workflows/ci.yml",
        ".github/pull_request_template.md",
        ".github/ISSUE_TEMPLATE/agentic-work-packet.md",
    ]:
        if not (ROOT / name).exists():
            fail(f"{name}: required delivery scaffold file is missing")


def check_executable_scripts() -> None:
    for name in [
        "scripts/dev",
        "scripts/test",
        "scripts/lint",
        "scripts/build",
        "scripts/smoke",
        "scripts/dogfood-android",
        "scripts/agentic-cycle",
        "scripts/agentic-harness",
        "scripts/release-audit",
    ]:
        path = ROOT / name
        if path.exists() and not os.access(path, os.X_OK):
            fail(f"{name}: script must be executable")


def check_agent_docs() -> None:
    required = {
        "AGENTS.md": [
            "Domain Map",
            "Commands",
            "Architecture Guardrails",
            "Agentic Engineering Rule",
            "docs/agentic-delivery.md",
            "scripts/agentic-harness",
            "scripts/agentic-cycle",
            "scripts/release-audit",
            "scripts/dogfood-android",
            "docs/adr/0001-playback-timeline-source-of-truth.md",
        ],
        "docs/context-map.md": [
            "Harness Matrix",
            "Playback Session And Queue Timeline",
            "Audio Analysis And DJ Waveforms",
            "Agentic Delivery And Release Gates",
            "scripts/agentic-harness",
            "scripts/agentic-cycle",
            "scripts/release-audit",
            "scripts/dogfood-android",
            "docs/adr/0001-playback-timeline-source-of-truth.md",
        ],
        "docs/agentic-delivery.md": [
            "Work Packet",
            "Exact-Head Gates",
            "Mobile And Audio Dogfood",
            "Resource Closeout",
            "scripts/lint delivery",
            "scripts/agentic-cycle",
            "scripts/release-audit",
            "scripts/dogfood-android",
        ],
        ".github/pull_request_template.md": [
            "Intent",
            "Context map",
            "Harness / backpressure",
            "Agentic dev-cycle plan/evidence",
            "Gate classification",
            "Exact-head evidence",
            "scripts/agentic-cycle",
            "scripts/release-audit",
            "Android APK SHA256",
            "docs/agentic-delivery.md",
        ],
        ".github/ISSUE_TEMPLATE/agentic-work-packet.md": [
            "Intent",
            "Context Map",
            "Harness / Backpressure",
            "Risk Seams",
            "Acceptance",
        ],
        "docs/adr/0001-playback-timeline-source-of-truth.md": [
            "QueueTimelineController",
            "PlaybackSnapshot",
            "TimelineModel",
            "VoicePool",
            "scripts/agentic-harness",
        ],
    }
    for name, phrases in required.items():
        path = ROOT / name
        if not path.exists():
            continue
        text = path.read_text(errors="replace")
        for phrase in phrases:
            if phrase not in text:
                fail(f"{name}: missing required delivery phrase {phrase!r}")


def check_ci_wires_harness() -> None:
    path = ROOT / ".github/workflows/ci.yml"
    if not path.exists():
        return
    text = path.read_text(errors="replace")
    required_phrases = [
        "scripts/lint delivery",
        "scripts/agentic-cycle --committed-only",
        "scripts/release-audit --self-test",
        "scripts/lint backend",
        "scripts/test backend",
        "scripts/build backend",
        "scripts/lint client",
        "scripts/test client",
        "scripts/build client",
        "scripts/lint extension",
        "scripts/test extension",
        "scripts/build extension",
        "scripts/dev isolated",
        "scripts/smoke isolated",
        "scripts/smoke playback-isolated",
    ]
    for phrase in required_phrases:
        if phrase not in text:
            fail(f".github/workflows/ci.yml: CI must run {phrase}")


def check_local_dev_contracts() -> None:
    required_phrases = {
        ".gitignore": ["outputs/", "deploy/.env"],
        "scripts/dev": ["test-infra", "test-infra-isolated"],
        "scripts/local-low-memory.sh": ["test-infra", "WORKER_COUNT=0"],
        "docs/LOW_MEMORY_LOCAL_DEV.md": [
            "scripts/dev test-infra",
            "scripts/dev test-infra-isolated",
        ],
        "docs/context-map.md": ["scripts/dev test-infra"],
        "docs/agentic-delivery.md": ["scripts/dev test-infra"],
    }
    for name, phrases in required_phrases.items():
        path = ROOT / name
        if not path.exists():
            fail(f"{name}: required local dev contract file is missing")
            continue
        text = path.read_text(errors="replace")
        for phrase in phrases:
            if phrase not in text:
                fail(f"{name}: missing local dev contract phrase {phrase!r}")


def check_json_syntax(files: list[Path]) -> None:
    for path in files:
        if path.suffix.lower() != ".json":
            continue
        try:
            json.loads(path.read_text(errors="replace"))
        except Exception as exc:
            fail(f"{rel(path)}: invalid json: {exc}")


def check_python_syntax(files: list[Path]) -> None:
    for path in files:
        if path.suffix.lower() != ".py" and rel(path) not in {
            "scripts/agentic-harness",
            "scripts/agentic-cycle",
        }:
            continue
        try:
            ast.parse(path.read_text(errors="replace"), filename=str(path))
        except SyntaxError as exc:
            fail(f"{rel(path)}: python syntax error: {exc}")


def check_bash_syntax(files: list[Path]) -> None:
    for path in files:
        text = read_text(path)
        if not text or not text.startswith("#!") or "bash" not in text.splitlines()[0]:
            continue
        result = subprocess.run(
            ["bash", "-n", str(path)],
            cwd=ROOT,
            text=True,
            capture_output=True,
            check=False,
        )
        if result.returncode != 0:
            fail(f"{rel(path)}: bash syntax error: {result.stderr.strip()}")


def check_secret_scan(files: list[Path]) -> None:
    for path in files:
        text = read_text(path)
        if text is None:
            continue
        for line_no, line in enumerate(text.splitlines(), 1):
            low = line.lower()
            if any(hint in low for hint in PLACEHOLDER_HINTS):
                continue
            if any(pattern.search(line) for pattern in SECRET_PATTERNS):
                fail(f"{rel(path)}:{line_no}: secret-like value")


def check_architecture_guardrails(files: list[Path]) -> None:
    canonical_files = [
        "backend/internal/db/db.go",
        "client/lib/core/audio/playback_state.dart",
        "client/lib/core/audio/queue_timeline_controller.dart",
        "client/lib/core/audio/playback_session.dart",
        "client/lib/core/audio/mix_audio_handler.dart",
        "client/lib/core/engine/playback_engine.dart",
        "client/lib/core/engine/timeline_clock.dart",
        "client/lib/core/engine/timeline_model.dart",
        "client/lib/core/engine/voice_pool.dart",
    ]
    for name in canonical_files:
        if not (ROOT / name).exists():
            fail(f"{name}: required architecture guardrail file is missing")

    playback_state = ROOT / "client/lib/core/audio/playback_state.dart"
    if playback_state.exists():
        text = playback_state.read_text(errors="replace")
        if "QueueTimelineController _queueController" not in text:
            fail("client/lib/core/audio/playback_state.dart: must own QueueTimelineController as playback source of truth")
        if "PlaybackSnapshot get snapshot => _queueController.snapshot" not in text:
            fail("client/lib/core/audio/playback_state.dart: public snapshot must come from QueueTimelineController")

    queue_controller = ROOT / "client/lib/core/audio/queue_timeline_controller.dart"
    if queue_controller.exists():
        text = queue_controller.read_text(errors="replace")
        for phrase in [
            "PlaybackSnapshot get snapshot",
            "BehaviorSubject<MediaItem?> _currentMediaItemSubject",
            "TimelineModel",
        ]:
            if phrase not in text:
                fail(f"client/lib/core/audio/queue_timeline_controller.dart: missing canonical playback phrase {phrase!r}")

    for path in files:
        if path.suffix.lower() != ".dart":
            continue
        path_rel = rel(path)
        text = read_text(path) or ""
        if (
            "_currentMediaItemSubject" in text
            and path_rel != "client/lib/core/audio/queue_timeline_controller.dart"
        ):
            fail(f"{path_rel}: current media item subject must stay inside QueueTimelineController")
        if re.search(r"class\s+\w*(?:Playback|Transport)Controller\b", text):
            if path_rel != "client/lib/core/audio/queue_timeline_controller.dart":
                fail(f"{path_rel}: do not introduce a second playback/transport controller")

    if (ROOT / "Cargo.toml").exists():
        fail("Cargo.toml: root Rust/sqlx migration stack must not be reintroduced")
    if (ROOT / "migrations").exists():
        fail("migrations/: root migrations directory must not be reintroduced; backend/internal/db/db.go is schema authority")


def main() -> int:
    files = repo_files()
    check_required_files()
    check_executable_scripts()
    check_agent_docs()
    check_ci_wires_harness()
    check_local_dev_contracts()
    check_json_syntax(files)
    check_python_syntax(files)
    check_bash_syntax(files)
    check_secret_scan(files)
    check_architecture_guardrails(files)

    if FAILURES:
        print("AGENTIC HARNESS FAILED")
        for item in FAILURES:
            print(f"- {item}")
        return 1

    print("AGENTIC HARNESS OK")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
