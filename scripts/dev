#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BACKEND_BASE_URL="${OMP_BACKEND_BASE_URL:-http://localhost:${SERVER_PORT:-8080}}"
FLUTTER_API_BASE_URL="${OMP_FLUTTER_API_BASE_URL:-${OMP_API_BASE_URL:-$BACKEND_BASE_URL/api/v1}}"
WEB_HOST="${OMP_WEB_HOST:-127.0.0.1}"
WEB_PORT="${OMP_WEB_PORT:-8088}"

use_isolated_ports() {
  local offset
  offset="$(printf '%s' "${OMP_ISOLATED_PORT_SEED:-$ROOT}" | cksum | awk '{print $1 % 1000}')"
  export SERVER_PORT="${SERVER_PORT:-$((18080 + offset))}"
  export POSTGRES_PORT="${POSTGRES_PORT:-$((25000 + offset))}"
  export REDIS_PORT="${REDIS_PORT:-$((26000 + offset))}"
  export MINIO_PORT="${MINIO_PORT:-$((27000 + offset))}"
  export MINIO_CONSOLE_PORT="${MINIO_CONSOLE_PORT:-$((28000 + offset))}"
  export OMP_BACKEND_BASE_URL="${OMP_BACKEND_BASE_URL:-http://localhost:${SERVER_PORT}}"
}

case "${1:-low-memory}" in
  low-memory|backend)
    exec "$ROOT/scripts/local-low-memory.sh" start
    ;;
  isolated|codex)
    use_isolated_ports
    exec "$ROOT/scripts/local-low-memory.sh" start
    ;;
  test-infra)
    exec "$ROOT/scripts/local-low-memory.sh" test-infra
    ;;
  test-infra-isolated|isolated-test-infra)
    use_isolated_ports
    exec "$ROOT/scripts/local-low-memory.sh" test-infra
    ;;
  full)
    cd "$ROOT"
    exec docker compose up -d
    ;;
  flutter-web)
    cd "$ROOT/client"
    exec flutter run -d web-server \
      --web-hostname "$WEB_HOST" \
      --web-port "$WEB_PORT" \
      --dart-define="OMP_API_BASE_URL=$FLUTTER_API_BASE_URL"
    ;;
  *)
    echo "usage: scripts/dev [low-memory|backend|isolated|codex|test-infra|test-infra-isolated|full|flutter-web]" >&2
    exit 2
    ;;
esac
