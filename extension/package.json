{
  "name": "open-music-player-extension",
  "version": "1.0.0",
  "description": "Sound Q browser extension",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "test:auth-refresh": "tsc -p test/tsconfig.json && node test/dist/test/auth_refresh_regression.js && node test/dist/test/background_auth_regression.js",
    "test:brand-assets": "npm run build && tsc -p test/tsconfig.json && node test/dist/test/brand_assets_regression.js",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "copy-webpack-plugin": "^12.0.2",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
