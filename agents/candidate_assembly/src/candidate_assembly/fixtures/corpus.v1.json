        "topCandidateId": "youtube:vondutch-audio",
        "topClassificationAnyOf": ["official_audio", "topic_audio"],
        "forbiddenInTopK": {"k": 3, "classifications": ["music_video", "lyric_video"]}
      }
    },
    {
